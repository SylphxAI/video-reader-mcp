#!/usr/bin/env bash
set -euo pipefail
ROOT="$(cd "$(dirname "$0")/.." && pwd)"

resolve_rust_bin() {
  if [[ -x "$ROOT/bin/native/video-reader-mcp-server" ]]; then
    echo "$ROOT/bin/native/video-reader-mcp-server"
    return 0
  fi
  if [[ -x "$ROOT/target/release/video-reader-mcp-server" ]]; then
    echo "$ROOT/target/release/video-reader-mcp-server"
    return 0
  fi
  if [[ -x "$ROOT/target/debug/video-reader-mcp-server" ]]; then
    echo "$ROOT/target/debug/video-reader-mcp-server"
    return 0
  fi
  return 1
}

resolve_transport() {
  if [[ -n "${1:-}" ]]; then
    echo "$1"
    return 0
  fi
  if [[ -n "${VIDEO_READER_MCP_TRANSPORT:-}" ]]; then
    echo "${VIDEO_READER_MCP_TRANSPORT}"
    return 0
  fi
  if [[ -n "${MCP_TRANSPORT:-}" ]]; then
    echo "${MCP_TRANSPORT}"
    return 0
  fi
  echo "rust"
}

transport="$(resolve_transport "${1:-}")"

# HTTP always prefers Rust streamable HTTP when native present
if [[ "$transport" == "http" ]]; then
  if rust_bin="$(resolve_rust_bin)"; then
    export MCP_TRANSPORT=http
    exec "$rust_bin"
  fi
  echo "video-reader-mcp: MCP_TRANSPORT=http requires Rust video-reader-mcp-server binary" >&2
  exit 1
fi

# explicit TS stdio opt-in after HTTP branch
if [[ "$transport" == "ts" ]]; then
  exec bun "$ROOT/src/index.ts"
fi

if rust_bin="$(resolve_rust_bin)"; then
  exec "$rust_bin"
fi

# fallback TS stdio
exec bun "$ROOT/src/index.ts"
